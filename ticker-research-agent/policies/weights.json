{
  "schema_version": "1.0",
  "description": "Per-dimension weights for the composite conviction score and per-asset-class subscore variants. Loop 11 reads this; tuning these adjusts overall scoring without touching subagent code.",
  "weights": {
    "STOCK": {
      "earnings_fundamentals":      0.20,
      "institutional_activity":     0.15,
      "momentum_price":             0.12,
      "valuation_fair_value":       0.12,
      "analyst_sentiment":          0.10,
      "news_catalyst":              0.10,
      "quant_factor":               0.08,
      "options_short_interest":     0.05,
      "social_community_sentiment": 0.04,
      "sector_macro":               0.04
    },
    "ETF": {
      "earnings_fundamentals":      0.10,
      "institutional_activity":     0.18,
      "momentum_price":             0.18,
      "valuation_fair_value":       0.10,
      "analyst_sentiment":          0.05,
      "news_catalyst":              0.10,
      "quant_factor":               0.10,
      "options_short_interest":     0.05,
      "social_community_sentiment": 0.04,
      "sector_macro":               0.10,
      "_note": "ETF replaces earnings_fundamentals with holdings/NAV health; institutional_activity captures fund flows."
    },
    "CRYPTO": {
      "earnings_fundamentals":      0.18,
      "institutional_activity":     0.15,
      "momentum_price":             0.15,
      "valuation_fair_value":       0.10,
      "analyst_sentiment":          0.04,
      "news_catalyst":              0.10,
      "quant_factor":               0.05,
      "options_short_interest":     0.08,
      "social_community_sentiment": 0.07,
      "sector_macro":               0.08,
      "_note": "earnings_fundamentals = on-chain health (MVRV, holders, fees, NUPL). institutional_activity = ETF flows + treasuries. options_short_interest = perp funding + futures basis + skew."
    }
  },
  "sign_conventions": {
    "description": "Per-dimension rules for whether a high subscore means BULLISH or BEARISH. The composite formula is sum(score * weight); a dimension's `direction` field flips the sign before contribution.",
    "always_bullish_when_high": [
      "earnings_fundamentals", "institutional_activity", "momentum_price",
      "valuation_fair_value", "analyst_sentiment", "quant_factor"
    ],
    "context_dependent": {
      "news_catalyst": "Direction depends on catalyst type (positive vs negative news). Loop 5 must set the direction field per evidence cluster.",
      "options_short_interest": "High SI + falling price = bearish; high SI + rising price + low days-to-cover = squeeze setup (bullish).",
      "social_community_sentiment": "High retail sentiment can be contrarian (frothy top) — Loop 6 evaluates retail-vs-institutional divergence to set direction.",
      "sector_macro": "Direction depends on macro regime classification (BULLISH/NEUTRAL/BEARISH/STAGFLATION) and the ticker's beta to that regime."
    }
  },
  "subscore_inputs": {
    "earnings_fundamentals": {
      "components": [
        { "name": "earnings_beat_streak", "weight": 0.20 },
        { "name": "revenue_growth_yoy", "weight": 0.20 },
        { "name": "margin_trend", "weight": 0.15 },
        { "name": "fcf_yield", "weight": 0.15 },
        { "name": "balance_sheet_health", "weight": 0.15 },
        { "name": "guidance_vs_consensus", "weight": 0.15 }
      ]
    },
    "institutional_activity": {
      "components": [
        { "name": "13f_position_change_qoq", "weight": 0.30 },
        { "name": "insider_net_buying_6m", "weight": 0.25 },
        { "name": "dark_pool_signal", "weight": 0.15 },
        { "name": "ownership_pct_change", "weight": 0.15 },
        { "name": "ftd_trend", "weight": 0.15 }
      ]
    },
    "momentum_price": {
      "components": [
        { "name": "12_1_momentum_percentile", "weight": 0.30 },
        { "name": "200d_sma_position", "weight": 0.20 },
        { "name": "rs_vs_sector", "weight": 0.20 },
        { "name": "rsi_macd_alignment", "weight": 0.15 },
        { "name": "volume_confirmation", "weight": 0.15 }
      ]
    },
    "valuation_fair_value": {
