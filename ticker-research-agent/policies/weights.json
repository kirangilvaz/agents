        { "name": "pead_setup", "weight": 0.15 },
        { "name": "short_interest_anomaly", "weight": 0.15 }
      ]
    },
    "options_short_interest": {
      "components": [
        { "name": "iv_rank", "weight": 0.20 },
        { "name": "put_call_ratio_skew", "weight": 0.20 },
        { "name": "unusual_activity_signal", "weight": 0.20 },
        { "name": "short_interest_pct_float", "weight": 0.20 },
        { "name": "days_to_cover_squeeze", "weight": 0.20 }
      ]
    },
    "social_community_sentiment": {
      "components": [
        { "name": "reddit_sentiment_7d", "weight": 0.25 },
        { "name": "stocktwits_sentiment", "weight": 0.20 },
        { "name": "twitter_cashtag_velocity", "weight": 0.20 },
        { "name": "retail_inst_divergence", "weight": 0.20 },
        { "name": "narrative_recurrence", "weight": 0.15 }
      ]
    },
    "sector_macro": {
      "components": [
        { "name": "regime_alignment", "weight": 0.30 },
        { "name": "sector_rotation_signal", "weight": 0.25 },
        { "name": "rate_sensitivity_match", "weight": 0.20 },
        { "name": "policy_tailwind", "weight": 0.15 },
        { "name": "geopolitical_exposure", "weight": 0.10 }
