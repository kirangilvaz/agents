        { "name": "target_revision_30d", "weight": 0.25 },
        { "name": "estimate_revision_30d", "weight": 0.20 }
      ]
    },
    "news_catalyst": {
      "components": [
        { "name": "news_sentiment_72h", "weight": 0.30 },
