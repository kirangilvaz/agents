{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_record.schema.json",
  "title": "Evidence Record",
  "description": "One JSONL line per source confirmation per opportunity. Stored at novelty_explorer_memory/evidence/<opportunity_id>.jsonl. Append-only. Loop 4 reads these to compute independent_source_count after citation-cycle dedup; Loop 5 (adversarial) re-validates against exact_quote.",
  "type": "object",
  "required": [
    "evidence_id",
    "opportunity_id",
    "signal_class",
    "source_domain",
    "source_tier",
    "url",
    "url_hash",
    "fetched_at",
    "exact_quote",
    "confirmed_in_cycle"
  ],
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,}$", "description": "ULID or UUID. Primary key." },
    "opportunity_id": { "type": "string" },
    "signal_class": {
      "type": "string",
      "enum": ["scientific", "startup", "investment", "community", "patent"],
      "description": "Which of the five source tiers this came from."
    },
    "feeds_dimension": {
      "type": "array",
      "items": { "type": "string", "enum": ["novelty", "capital", "momentum", "feasibility", "market"] },
      "description": "Which scoring dimension(s) this evidence informs."
    },
    "source_domain": { "type": "string", "description": "lowercase, no scheme (e.g. 'arxiv.org')." },
    "source_tier": { "type": "integer", "enum": [1, 2, 3, 4, 5] },
    "url": { "type": "string", "format": "uri" },
    "url_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "fetched_at": { "type": "string", "format": "date-time" },
    "report_date": { "type": ["string", "null"], "format": "date", "description": "Date the source data point reflects (publish / filing / round / commit date)." },
    "exact_quote": { "type": "string", "minLength": 10, "description": "Verbatim excerpt so Loop 5 can re-validate." },
    "data_point": {
      "type": "object",
      "additionalProperties": true,
      "description": "Structured extraction; varies by signal_class.",
      "properties": {
        "metric": { "type": "string", "description": "e.g. 'citation_count', 'github_stars', 'round_amount_usd_m', 'patent_filings_12m'." },
        "value": { "type": ["number", "string", "boolean", "null"] },
        "unit": { "type": "string" },
        "prior_value": { "type": ["number", "null"], "description": "For growth-rate signals." },
        "as_of": { "type": "string", "format": "date" }
      }
    },
    "cites": { "type": "array", "items": { "type": "string", "format": "uri" }, "description": "URLs this record cites — used by Loop 4 for citation-cycle dedup." },
    "cited_by": { "type": "array", "items": { "type": "string", "format": "uri" } },
    "confirmed_in_cycle": { "type": "integer", "minimum": 1 },
    "rescraped_in_cycles": { "type": "array", "items": { "type": "integer" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Extractor confidence the quote supports the claimed signal. <0.7 excluded by Loop 4." },
    "data_age_days": { "type": "integer", "minimum": 0 },
    "fetch_status": { "type": "string", "enum": ["ok", "paywalled", "via_archive", "via_reader", "403", "404", "429", "timeout", "robots_disallowed", "error"], "default": "ok" },
    "is_counter_evidence": { "type": "boolean", "default": false, "description": "Loop 5 marks adversarial counter-evidence; surfaced in risks but NOT counted toward independent_source_count." }
  }
}
